PORT=8787
# Mock response for GET /api/v1/subscription
# status: active | trialing | past_due | canceling | canceled | none
MOCK_SUBSCRIPTION_STATUS=none
MOCK_TIER=
# Optional relative end date in days for renewal / trial / cancellation previews.
MOCK_VALID_UNTIL_DAYS=0
# When true, the remote catalog seed marks premium rows as playable bundled charts.
MOCK_PREMIUM_PLAYABLE=false

# Stripe (optional — webhook verifies signature only when both are set)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_BLUES_PACK=
STRIPE_PRICE_FINGERSTYLE_PACK=
STRIPE_CHECKOUT_SUCCESS_URL=http://127.0.0.1:5173/account?billing=success
STRIPE_CHECKOUT_CANCEL_URL=http://127.0.0.1:5173/account?billing=cancel
STRIPE_BILLING_PORTAL_RETURN_URL=http://127.0.0.1:5173/account?billing=portal
