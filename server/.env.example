PORT=8787
# Mock response for GET /api/v1/subscription
# status: active | trialing | past_due | canceling | canceled | none
MOCK_SUBSCRIPTION_STATUS=none
MOCK_TIER=
# Optional relative end date in days for renewal / trial / cancellation previews.
MOCK_VALID_UNTIL_DAYS=0

# Stripe (optional — webhook verifies signature only when both are set)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
