{
  "name": "fretflow",
  "version": "0.1.0",
  "description": "Fretflow — learn guitar with play-along tab practice (desktop)",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "validate-charts": "tsx scripts/validate-charts.ts",
    "midi-to-chart": "tsx scripts/midi-to-chart.ts",
    "assert-midi-golden": "tsx scripts/assert-midi-golden.ts",
    "generate-smoke-mid": "tsx scripts/generate-smoke-mid.ts",
    "generate-tempo-ramp-mid": "tsx scripts/generate-tempo-ramp-mid.ts",
    "generate-chord-smoke-mid": "tsx scripts/generate-chord-smoke-mid.ts",
    "lint": "npm run check",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "tauri": "tauri"
  },
  "license": "MIT",
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.9.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tauri-apps/cli": "^2",
    "midi-file": "^1.2.4",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "~5.6.2",
    "vite": "^6.0.3"
  }
}
